{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bazel Execution Log",
  "scopeName": "source.bazel-execlog",
  "patterns": [
    { "include": "#comment" },
    { "include": "#divider" },
    { "include": "#string-double" },
    { "include": "#string-single" },
    { "include": "#boolean" },
    { "include": "#number" },
    { "include": "#message-name" },
    { "include": "#identifier" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.bazel-execlog",
      "match": "#.*$"
    },
    "divider": {
      "name": "comment.line.divider.bazel-execlog",
      "match": "^-{3,}\\s*$"
    },
    "message-name": {
      "name": "entity.name.tag.message.bazel-execlog",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\{)"
    },
    "string-double": {
      "name": "string.quoted.double.bazel-execlog",
      "begin": "\"",
      "end": "\"|$",
      "patterns": [
        { "include": "#escape" }
      ]
    },
    "string-single": {
      "name": "string.quoted.single.bazel-execlog",
      "begin": "'",
      "end": "'|$",
      "patterns": [
        { "include": "#escape" }
      ]
    },
    "escape": {
      "patterns": [
        {
          "name": "constant.character.escape.bazel-execlog",
          "match": "\\\\(?:[abfnrtv?\\\\'\"]|[0-7]{1,3}|x[0-9a-fA-F]{1,2}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
        },
        {
          "name": "invalid.illegal.unknown-escape.bazel-execlog",
          "match": "\\\\."
        }
      ]
    },
    "boolean": {
      "name": "constant.language.boolean.bazel-execlog",
      "match": "\\b(true|false)\\b"
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.bazel-execlog",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.octal.bazel-execlog",
          "match": "\\b0[0-7]+\\b"
        },
        {
          "name": "constant.numeric.float.bazel-execlog",
          "match": "(?:\\b\\d+\\.\\d*|\\B\\.\\d+)(?:[eE][+-]?\\d+)?[fF]?\\b|\\b\\d+[eE][+-]?\\d+[fF]?\\b|\\b\\d+[fF]\\b"
        },
        {
          "name": "constant.numeric.integer.bazel-execlog",
          "match": "\\b(?:0|[1-9]\\d*)\\b"
        }
      ]
    },
    "identifier": {
      "name": "variable.other.field.bazel-execlog",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.bazel-execlog",
          "match": ":"
        },
        {
          "name": "keyword.operator.assignment.bazel-execlog",
          "match": "="
        },
        {
          "name": "punctuation.separator.comma.bazel-execlog",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.bazel-execlog",
          "match": ";"
        },
        {
          "name": "punctuation.separator.dot.bazel-execlog",
          "match": "\\."
        },
        {
          "name": "punctuation.section.braces.begin.bazel-execlog",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.bazel-execlog",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.bazel-execlog",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.bazel-execlog",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.angle.begin.bazel-execlog",
          "match": "<"
        },
        {
          "name": "punctuation.section.angle.end.bazel-execlog",
          "match": ">"
        }
      ]
    }
  }
}
