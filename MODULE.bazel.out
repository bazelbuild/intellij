IC_253_URL = "https://www.jetbrains.com/intellij-repository/releases/com/jetbrains/intellij/idea/ideaIC/2025.3.4/ideaIC-2025.3.4.zip"

http_archive(
    name = "intellij_ce_2025_3",
    build_file = "@//intellij_platform_sdk:BUILD.idea253",
    sha256 = IC_253_SHA,
    url = IC_253_URL,
)

